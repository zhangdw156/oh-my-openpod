# ================================================================
# 官方托管服务 API Key
# ================================================================

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT / o 系列)
# OPENAI_API_KEY=sk-xxxxx

# ================================================================
# 自部署 / 第三方兼容接口
# 配合 opencode.json 中的 provider 定义一起使用
# ================================================================

# --- OpenAI 兼容格式（vLLM / Ollama / LiteLLM / 硅基流动 等）---
# CUSTOM_OPENAI_BASE_URL=https://your-host/v1
# CUSTOM_OPENAI_API_KEY=your-api-key
# CUSTOM_OPENAI_MODEL=your-model-name

# --- Anthropic 兼容格式（自部署 Claude / AWS Bedrock 代理 等）---
# CUSTOM_ANTHROPIC_BASE_URL=https://your-host
# CUSTOM_ANTHROPIC_API_KEY=your-api-key
# CUSTOM_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ================================================================
# 挂载路径
# ================================================================

# 要挂载到容器 /workspace 的本地项目目录（默认 ~/projects）
# PROJECT_DIR=~/projects

# ================================================================
# OpenCode 配置文件路径
# 默认使用仓库内的 opencode.json.example（只读示例）
# 建议复制为 opencode.json 并按需修改后指向它
# ================================================================
# OPENCODE_CONFIG=./opencode.json
