# ---- AI Provider API Keys (按需填写) ----
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# ---- 挂载路径 ----
# 要挂载到容器 /workspace 的本地项目目录（默认 ~/projects）
# PROJECT_DIR=~/projects

# ---- OpenCode 配置 ----
# 自定义 opencode 配置文件路径（默认使用仓库内的 opencode.json.example）
# 建议复制 opencode.json.example 为 opencode.json 并修改后指向它
# OPENCODE_CONFIG=./opencode.json
