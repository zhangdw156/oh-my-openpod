{
  "$schema": "https://opencode.ai/config.json",
  "provider": {

    // ----------------------------------------------------------------
    // 示例 1：OpenAI 兼容接口（vLLM / Ollama / LiteLLM / 硅基流动 等）
    // 对应 .env 中的 CUSTOM_OPENAI_* 变量
    // ----------------------------------------------------------------
    "custom-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "My OpenAI-Compatible Provider",
      "options": {
        "baseURL": "${CUSTOM_OPENAI_BASE_URL}",
        "apiKey": "${CUSTOM_OPENAI_API_KEY}"
      },
      "models": {
        "${CUSTOM_OPENAI_MODEL}": {
          "name": "${CUSTOM_OPENAI_MODEL}"
        }
      }
    },

    // ----------------------------------------------------------------
    // 示例 2：Anthropic 兼容接口（自部署 Claude / AWS Bedrock 代理 等）
    // 对应 .env 中的 CUSTOM_ANTHROPIC_* 变量
    // ----------------------------------------------------------------
    "custom-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "My Anthropic-Compatible Provider",
      "options": {
        "baseURL": "${CUSTOM_ANTHROPIC_BASE_URL}",
        "apiKey": "${CUSTOM_ANTHROPIC_API_KEY}"
      },
      "models": {
        "${CUSTOM_ANTHROPIC_MODEL}": {
          "name": "${CUSTOM_ANTHROPIC_MODEL}"
        }
      }
    }

  }
}
